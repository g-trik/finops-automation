        "responses": {
          "values": [
            {
              "content": "=Extract the following fields from this invoice text and return \nONLY valid JSON, no explanation:\n{\n  \"vendor_name\": \"\",\n  \"invoice_number\": \"\",\n  \"invoice_date\": \"\",\n  \"due_date\": \"\",\n  \"total_amount\": 0,\n  \"currency\": \"\",\n  \"vat_amount\": 0,\n  \"line_items\": [],\n  \"anomalies\": []\n}\n\nInvoice text: {{ $json.text }}"
            }
          ]
        },
        "builtInTools": {},
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 2.1,
      "position": [
        1056,
        80
      ],
      "id": "786cccaa-50dc-43d8-b54b-7f7d1b294ad0",
      "name": "Retrieve relevant doc info fields",
      "credentials": {
        "openAiApi": {
          "id": "YOUR_OPENAI_CREDENTIAL_ID",
          "name": "OpenAi account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const output = $input.first().json?.output;\n\n// Case 6: No output at all\nif (!output || !output[0]?.content?.[0]?.text) {\n  return [{\n    json: {\n      vendor_name: '', invoice_number: '', invoice_date: '',\n      due_date: '', total_amount: 0, currency: '', vat_amount: 0,\n      line_items: [], anomalies: [],\n      status: 'FLAGGED',\n      flags: 'No content extracted — file may be corrupted or empty',\n      parse_error: true,\n      error_type: 'NO_CONTENT'\n    }\n  }];\n}\n\nconst text = output[0].content[0].text.trim();\n\n// Case 2 & 5: OpenAI responded conversationally (no JSON)\nconst looksLikeJson = text.startsWith('{') || text.includes('```json');\nif (!looksLikeJson) {\n  return [{\n    json: {\n      vendor_name: '', invoice_number: '', invoice_date: '',\n      due_date: '', total_amount: 0, currency: '', vat_amount: 0,\n      line_items: [], anomalies: [],\n      status: 'FLAGGED',\n      flags: 'File does not appear to contain invoice data — scanned image or unreadable content',\n      parse_error: true,\n      error_type: 'NOT_INVOICE_CONTENT'\n    }\n  }];\n}\n\n// Attempt JSON parse\nconst clean = text.replace(/```json|```/g, '').trim();\nlet invoice;\ntry {\n  invoice = JSON.parse(clean);\n} catch (e) {\n  // Case 3 & 7: Malformed JSON\n  return [{\n    json: {\n      vendor_name: '', invoice_number: '', invoice_date: '',\n      due_date: '', total_amount: 0, currency: '', vat_amount: 0,\n      line_items: [], anomalies: [],\n      status: 'FLAGGED',\n      flags: 'Could not parse invoice data — file may be a non-invoice document or use unsupported formatting',\n      parse_error: true,\n      error_type: 'PARSE_FAILED'\n    }\n  }];\n}\n\n// Case 4: Partial JSON — fill in missing fields with safe defaults\nconst safeInvoice = {\n  vendor_name:     invoice.vendor_name     ?? '',\n  invoice_number:  invoice.invoice_number  ?? '',\n  invoice_date:    invoice.invoice_date    ?? '',\n  due_date:        invoice.due_date        ?? '',\n  total_amount:    invoice.total_amount    ?? 0,\n  currency:        invoice.currency        ?? '',\n  vat_amount:      invoice.vat_amount      ?? 0,\n  line_items:      invoice.line_items      ?? [],\n  anomalies:       invoice.anomalies       ?? [],\n  parse_error:     false,\n  error_type: invoice.error_type ?? 'NONE'\n};\n\n// Case 1: Everything good\nreturn [{ json: safeInvoice }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1472,
        80
      ],
      "id": "db5d5be2-a658-4b6b-9112-196c7ab33434",
      "name": "Clean OpenAI output"
    },
    {
      "parameters": {
        "jsCode": "const invoice = $('Clean OpenAI output').first().json;\nconst flags = [];\nconst lookupData = $('Check for duplicates').first();\nconst isDuplicate = lookupData !== null &&\n                    lookupData.json.invoice_number !== undefined &&\n                    lookupData.json.invoice_number !== '' &&\n                    lookupData.json.invoice_number === invoice.invoice_number;\n\n// 1. Missing required fields\nconst required = ['vendor_name', 'invoice_number', 'invoice_date', 'due_date', 'total_amount', 'currency'];\nfor (const field of required) {\n  if (invoice[field] === undefined || invoice[field] === null || invoice[field] === '') {\n    flags.push(`Missing required field: ${field}`);\n  }\n}\n\n// 2. Amount > €10,000\nif (invoice.total_amount > 10000) {\n  flags.push(`High value invoice: €${invoice.total_amount} exceeds €10,000 threshold`);\n}\n\n// 3. Due date already passed\nif (invoice.due_date) {\n  const due = new Date(invoice.due_date);\n  const today = new Date();\n  today.setHours(0, 0, 0, 0);\n  if (due < today) {\n    flags.push(`Due date has passed: ${invoice.due_date}`);\n  }\n}\n\n// 4. Currency not EUR/USD/GBP\nconst allowedCurrencies = ['EUR', 'USD', 'GBP'];\nif (invoice.currency && !allowedCurrencies.includes(invoice.currency.toUpperCase())) {\n  flags.push(`Unsupported currency: ${invoice.currency}`);\n}\n\n// 5. Duplicate check\nif (isDuplicate) {\n  flags.push(`Duplicate invoice number: ${invoice.invoice_number}`);\n}\n\n// 6. VAT sanity check\nif (invoice.total_amount && invoice.vat_amount) {\n  const expectedVat = invoice.total_amount - (invoice.total_amount / 1.21);\n  const tolerance = 1.00;\n  if (Math.abs(invoice.vat_amount - expectedVat) > tolerance) {\n    flags.push(`VAT mismatch: declared €${invoice.vat_amount}, expected ~€${expectedVat.toFixed(2)}`);\n  }\n}\n\n// 7. Zero amount check\nif (invoice.total_amount === 0 && invoice.error_type === 'NONE') {\n  flags.push('Zero amount invoice — possible extraction error or credit note, requires review');\n}\n\nconst status = flags.length > 0 ? 'FLAGGED' : 'CLEAN';\n\nreturn [{\n  json: {\n    ...invoice,\n    status,\n    flags: flags.join('; '),\n    processed_at: new Date().toISOString(),\n    error_type: invoice.error_type ?? 'NONE'\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
