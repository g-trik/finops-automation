    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst articles = items.map(item => ({\n  title: item.json.title || '',\n  link: item.json.link || '',\n  pubDate: item.json.pubDate || item.json.isoDate || '',\n  summary: item.json.contentSnippet || item.json.content || item.json.description || ''\n}));\n\n// Bundle into a single string for OpenAI\nconst bundle = articles.map((a, i) =>\n  `[${i+1}] ${a.title}\\nDate: ${a.pubDate}\\nSummary: ${a.summary}\\nLink: ${a.link}`\n).join('\\n\\n');\n\nreturn [{ json: { articles, bundle, total: articles.length } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        640,
        -96
      ],
      "id": "3de0dee2-205e-4510-b714-e2a092f0dc86",
      "name": "Clean and unify article data "
    },
    {
      "parameters": {
        "modelId": {
          "__rl": true,
          "value": "gpt-5.4",
          "mode": "list",
          "cachedResultName": "GPT-5.4"
        },
        "responses": {
          "values": [
            {
              "content": "=You are a fintech intelligence analyst working for ING Bank.\n\nReview these ${$json.total} news articles and:\n1. Select only the 5 most relevant articles for a bank's FinOps/finance team\n2. For each selected article write a 2-sentence summary\n3. Return ONLY valid JSON, no explanation:\n\n{\n  \"articles\": [\n    {\n      \"title\": \"\",\n      \"relevance_score\": 0,\n      \"summary\": \"\",\n      \"category\": \"regulation|payments|AI|risk|market\",\n      \"link\": \"\"\n    }\n  ],\n  \"overall_theme\": \"\",\n  \"risk_alerts\": []\n}\n\nArticles:\n{{ $json.bundle }}"
            }
          ]
        },
        "builtInTools": {},
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 2.1,
      "position": [
        864,
        -96
      ],
      "id": "1d24484b-44c2-4bcd-8904-70a2fdfa2a61",
      "name": "Act as fintech analyst",
      "credentials": {
        "openAiApi": {
          "id": "YOUR_OPENAI_CREDENTIAL_ID",
          "name": "OpenAi account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.output[0].content[0].text;\nconst clean = raw.replace(/```json|```/g, '').trim();\nconst data = JSON.parse(clean);\ndata.date = new Date().toDateString();\ndata.processed_at = new Date().toISOString();\n\n// Build HTML once\nconst articlesHtml = data.articles.map(a =>\n  `<p><b>${a.title}</b> [${a.category}] — Score: ${a.relevance_score}<br>${a.summary}<br><a href=\"${a.link}\">Read more</a></p>`\n).join('');\n\nconst riskAlertsHtml = data.risk_alerts.length > 0\n  ? data.risk_alerts.map(r => `<li>${r}</li>`).join('')\n  : '<li>None today</li>';\n\nconst html = `\n<h2>🌍 FinOps Morning Intelligence Briefing</h2>\n<p><b>Date:</b> ${data.date}</p>\n<p><b>Overall Theme:</b> ${data.overall_theme}</p>\n<h3>⚠️ Risk Alerts</h3>\n<ul>${riskAlertsHtml}</ul>\n<h3>📰 Top 5 Articles</h3>\n${articlesHtml}\n<hr>\n<p><i>Generated by FinOps Intelligence Suite</i></p>\n`;\n\n// First item carries the html for Gmail\n// All items carry flat fields for Sheets\nconst rows = data.articles.map((article, index) => ({\n  json: {\n    date: data.date,\n    title: article.title,\n    category: article.category,\n    relevance_score: article.relevance_score,\n    summary: article.summary,\n    link: article.link,\n    processed_at: data.processed_at,\n    html: index === 0 ? html : null  // only item 1 carries html\n  }\n}));\n\nreturn rows;"
      },
